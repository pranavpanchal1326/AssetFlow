# AssetFlow frontend environment variables.
#
# Proxy mode (recommended for local dev): leave VITE_API_URL unset/commented.
# vite.config.js proxies /api and /uploads to http://localhost:4000, so the
# frontend can just call fetch("/api/...") and it reaches the backend without
# any CORS setup.
#
# Explicit URL mode: set VITE_API_URL if the backend runs on a different host
# or port (e.g. when frontend and backend are deployed separately).
# VITE_API_URL=http://localhost:4000/api

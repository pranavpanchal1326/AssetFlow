# AssetFlow backend environment variables.

# Secret used to sign JWTs. REQUIRED in production — the server refuses to
# boot with the built-in dev fallback outside development. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Port the API listens on.
PORT=4000

# Path to the SQLite database file (relative to server/ or absolute).
DB_PATH=./data.sqlite

# NODE_ENV=development | production
NODE_ENV=development
